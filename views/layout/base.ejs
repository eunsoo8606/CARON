<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- SEO & Open Graph Tags for Social Media Sharing -->
    <meta name="description" content="신차 장기렌트, 오토리스, 리스/렌트 승계 전문 플랫폼 CARON. 최적의 모빌리티 솔루션을 제안합니다.">
    <meta property="og:type" content="website">
    <meta property="og:title" content="CARON - 카온·신차 장기렌트·리스·승계 전문">
    <meta property="og:description" content="복잡한 승계부터 신차 렌트까지, 자동차 금융의 새로운 기준 CARON과 함께하세요.">
    <meta property="og:image" content="https://caron-opal.vercel.app/images/CARON.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:url" content="https://caron-opal.vercel.app">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="CARON - 카온·신차 장기렌트·리스·승계 전문">
    <meta name="twitter:description" content="자동차 금융의 새로운 기준 CARON.">
    <meta name="twitter:image" content="https://caron-opal.vercel.app/images/CARON.png">
    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon/favicon.ico" type="image/x-icon">
    <!-- Pretendard Font -->
    <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
    <!-- CSS Libraries -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/css/style.css">
    <style>
    .modal-close:hover { color: #111; }

    /* 플래너 프로필 스타일 */
    .modal-planner-profile {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 20px;
        background: #f8faff;
        border-radius: 20px;
        margin-bottom: 25px;
        border: 1px solid #eef2f8;
    }
    .modal-planner-profile .planner-thumb {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }
    .modal-planner-profile .planner-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .modal-planner-profile .planner-text .greeting {
        font-size: 13px;
        color: var(--primary);
        font-weight: 700;
        margin-bottom: 2px;
    }
    .modal-planner-profile .planner-text .name {
        font-size: 18px;
        font-weight: 800;
        color: #111;
        margin-bottom: 4px;
    }
    .modal-planner-profile .planner-text .sub {
        font-size: 13px;
        color: #888;
    }

    .modal-body { padding: 30px; }
    </style>
    <%- style %>
</head>

<body>
    <%- include('header') %>

        <main>
            <%- body %>
        </main>

        <!-- Quick Consultation Sidebar (Fixed Right) -->
        <% if (typeof hideSidebar==='undefined' || !hideSidebar) { %>
            <div class="quick-sidebar">
                <div class="sidebar-form-box">
                    <div class="sidebar-header">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                            class="lucide lucide-calculator">
                            <rect width="16" height="20" x="4" y="2" rx="2" />
                            <line x1="8" x2="16" y1="6" y2="6" />
                            <line x1="16" x2="16" y1="14" y2="18" />
                            <path d="M16 10h.01" />
                            <path d="M12 10h.01" />
                            <path d="M8 10h.01" />
                            <path d="M12 14h.01" />
                            <path d="M8 14h.01" />
                            <path d="M12 18h.01" />
                            <path d="M8 18h.01" />
                        </svg>
                        <span>빠른 견적문의</span>
                    </div>
                    <form class="sidebar-form">
                        <div class="input-wrap">
                            <input type="text" placeholder="성함*" required>
                            <input type="text" placeholder="차종">
                            <input type="tel" placeholder="연락처* ex) 01012341234" required>
                        </div>

                        <div class="contact-method">
                            <span class="method-label">견적안내방법</span>
                            <div class="method-group">
                                <label><input type="radio" name="method" value="tel" checked> 전화</label>
                                <label><input type="radio" name="method" value="sms"> 문자</label>
                                <label><input type="radio" name="method" value="katalk"> 카톡</label>
                            </div>
                        </div>

                        <div class="sidebar-agreement">
                            <label>
                                <input type="checkbox" required checked>
                                <span>개인정보 수집·이용 동의 <span class="view-link">[보기]</span></span>
                            </label>
                        </div>

                        <button type="submit" class="btn-sidebar-submit">상담신청하기</button>
                    </form>
                </div>

                <div class="sidebar-contact-info">
                    <a href="tel:1544-0000" class="contact-link tel">
                        <div class="contact-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                class="lucide lucide-phone">
                                <path
                                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                            </svg>
                        </div>
                        <span class="link-label">전화문의</span>
                        <div class="contact-text">
                            <p>전문상담원과 전화상담</p>
                            <strong>1544-0000</strong>
                        </div>
                    </a>
                    <div class="divider"></div>
                    <a href="#" class="contact-link kakao">
                        <div class="contact-icon">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/e/e3/KakaoTalk_logo.svg"
                                alt="Kakao" style="width: 24px;">
                        </div>
                        <span class="link-label">카톡상담</span>
                        <div class="contact-text">
                            <p>빠르고 편한</p>
                            <strong>카카오톡 상담</strong>
                        </div>
                    </a>
                </div>
                <button class="btn-quick-inquiry desktop-only-hidden">간편 견적문의</button>
            </div>
            <% } %>

                <%- include('footer') %>

    <!-- Quick Inquiry Modal for Mobile -->
    <div class="modal-overlay" id="inquiryModal">
        <div class="modal-content">
            <div class="modal-header">
                <h4>간편 견적문의</h4>
                <button class="modal-close" id="closeInquiryModal">&times;</button>
            </div>
            <div class="modal-body">
                <!-- 플래너 프로필 영역 (기본 숨김) -->
                <div id="modalPlannerProfile" class="modal-planner-profile" style="display: none;">
                    <div class="planner-thumb">
                        <img id="modalPlannerImg" src="" alt="플래너">
                    </div>
                    <div class="planner-text">
                        <p class="greeting">안녕하세요!</p>
                        <p class="name"><span id="modalPlannerName"></span> 플래너입니다.</p>
                        <p class="sub">전문적인 맞춤 상담을 도와드리겠습니다.</p>
                    </div>
                </div>

                <form class="modal-form">
                    <div class="input-group">
                        <label>성함</label>
                        <input type="text" name="name" placeholder="성함을 입력해주세요" required>
                    </div>
                    <div class="input-group">
                        <label>연락처</label>
                        <input type="tel" name="phone" placeholder="010-0000-0000" required>
                    </div>
                    <div class="input-group">
                        <label>관심차종</label>
                        <input type="text" name="car_model" placeholder="예) 제네시스 G80">
                    </div>
                    <div class="agreement-box">
                        <label>
                            <input type="checkbox" required checked>
                            개인정보 수집 및 이용 동의 (필수)
                        </label>
                    </div>
                    <button type="submit" class="btn-submit-modal">상담 신청하기</button>
                </form>
            </div>
        </div>
    </div>

                    <!-- JS Libraries -->
                    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
                    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
                    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
                    <script src="/js/main.js"></script>
                    <%- script %>
</body>

</html>