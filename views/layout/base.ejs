<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon/favicon.ico" type="image/x-icon">
    <!-- Pretendard Font -->
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
    <!-- CSS Libraries -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/css/style.css">
    <%- style %>
</head>
<body>
    <%- include('header') %>
    
    <main>
        <%- body %>
    </main>

    <!-- Quick Consultation Sidebar (Fixed Right) -->
    <% if (typeof hideSidebar === 'undefined' || !hideSidebar) { %>
    <div class="quick-sidebar">
        <div class="sidebar-form-box">
            <div class="sidebar-header">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calculator"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>
                <span>빠른 견적문의</span>
            </div>
            <form class="sidebar-form">
                <div class="input-wrap">
                    <input type="text" placeholder="성함*" required>
                    <input type="text" placeholder="차종">
                    <input type="tel" placeholder="연락처* ex) 01012341234" required>
                </div>
                
                <div class="contact-method">
                    <span class="method-label">견적안내방법</span>
                    <div class="method-group">
                        <label><input type="radio" name="method" value="tel" checked> 전화</label>
                        <label><input type="radio" name="method" value="sms"> 문자</label>
                        <label><input type="radio" name="method" value="katalk"> 카톡</label>
                    </div>
                </div>

                <div class="sidebar-agreement">
                    <label>
                        <input type="checkbox" required checked>
                        <span>개인정보 수집·이용 동의 <span class="view-link">[보기]</span></span>
                    </label>
                </div>

                <button type="submit" class="btn-sidebar-submit">상담신청하기</button>
            </form>
        </div>

        <div class="sidebar-contact-info">
            <a href="tel:15440000" class="contact-link">
                <div class="contact-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone-call"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.19-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/><path d="M14.05 2a9 9 0 0 1 8 8"/><path d="M14.05 6A5 5 0 0 1 18 10"/></svg>
                </div>
                <div class="contact-text">
                    <p>전문상담원과 전화상담</p>
                    <strong>1544-0000</strong>
                </div>
            </a>
            <div class="divider"></div>
            <a href="#" class="contact-link kakao">
                <div class="contact-icon">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/e/e3/KakaoTalk_logo.svg" alt="Kakao" style="width: 24px;">
                </div>
                <div class="contact-text">
                    <p>빠르고 편한</p>
                    <strong>카카오톡 상담</strong>
                </div>
            </a>
        </div>
    </div>
    <% } %>

    <%- include('footer') %>

    <!-- JS Libraries -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="/js/main.js"></script>
    <%- script %>
</body>
</html>
