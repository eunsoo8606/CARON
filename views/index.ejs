<div class="container">
    <!-- Hero Section - Contained and Rounded -->
    <section class="hero">
        <div class="swiper hero-swiper">
            <div class="swiper-wrapper">
                <% if (banners && banners.length > 0) { %>
                    <% banners.forEach(banner => { %>
                        <div class="swiper-slide" 
                             style="background-image: url('/api/image/<%= banner.image_id %>'); cursor: <%= banner.link_url ? 'pointer' : 'default' %>"
                             onclick="<%= banner.link_url ? `location.href='${banner.link_url}'` : '' %>">
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="swiper-slide" style="background-image: url('/images/banner_ex1.png');"></div>
                    <div class="swiper-slide" style="background-image: url('/images/banner_ex2.png');"></div>
                <% } %>
            </div>
            <div class="swiper-pagination"></div>
        </div>
    </section>
</div>

<!-- Vehicle List Section -->
<section class="vehicle-section">
    <div class="container">
        <div class="section-header">
            <h3 class="section-title">4월 인기 <span>TOP 10</span></h3>
            <a href="/car/search" class="view-more">더보기</a>
        </div>

        <% const vehicles=[ { name: '제네시스 G80' , price: '월 78만원~' , img: '/images/genesis.png' , tag: '인기' }, {
            name: '현대 그랜저' , price: '월 52만원~' , img: '/images/granger.png' , tag: '즉시출고' }, { name: '기아 EV6' ,
            price: '월 65만원~' , img: '/images/ev6.png' , tag: '전기차' }, { name: 'BMW 5시리즈' , price: '월 92만원~' ,
            img: 'https://images.unsplash.com/photo-1555215695-3004980ad54e?q=80&w=2070' , tag: '수입차' }, {
            name: '기아 카니발' , price: '월 58만원~' , img: '/images/canival.png' , tag: '패밀리카' }, { name: '제네시스 GV80' ,
            price: '월 88만원~' , img: 'https://images.unsplash.com/photo-1619767886558-efdc259cde1a?q=80&w=2070' ,
            tag: 'SUV' }, { name: '벤츠 E클래스' , price: '월 105만원~' ,
            img: 'https://images.unsplash.com/photo-1618843479313-40f8afb4b4d8?q=80&w=2070' , tag: 'Best' }, {
            name: '아우디 A6' , price: '월 85만원~' ,
            img: 'https://images.unsplash.com/photo-1606148332571-0f666b607ce1?q=80&w=2070' , tag: '할인' }, {
            name: '테슬라 Model Y' , price: '월 72만원~' ,
            img: 'https://images.unsplash.com/photo-1619767886558-efdc259cde1a?q=80&w=2070' , tag: '전기차' }, {
            name: '현대 싼타페' , price: '월 48만원~' , img: '/images/ssantafe.png' , tag: '가성비' } ]; %>
            <div class="swiper vehicle-swiper">
                <div class="swiper-wrapper">
                    <% vehicles.forEach(car=> { %>
                        <div class="swiper-slide vehicle-card">
                            <div class="card-img" style="background-image: url('<%= car.img %>')">
                                <span class="badge">
                                    <%= car.tag %>
                                </span>
                            </div>
                            <div class="card-body">
                                <h4 class="car-name">
                                    <%= car.name %>
                                </h4>
                                <p class="car-price">
                                    <%= car.price %>
                                </p>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>
    </div>
</section>

<!-- YouTube Section (Moved Up to align with Inquiry Sidebar) -->
<section class="youtube-section">
    <div class="container">
        <div class="section-header">
            <h3 class="section-title">오토플랜 <span>유튜브</span></h3>
            <p class="section-subtitle">다양한 차종의 생생한 출고 후기와 리뷰를 감상하세요.</p>
        </div>

        <div class="youtube-player-layout">
            <!-- Main Player Area -->
            <div class="player-main" id="mainPlayer">
                <% if (youtubeVideos && youtubeVideos.length > 0) { %>
                    <div class="main-video-card" data-video-id="<%= youtubeVideos[0].video_id %>">
                        <div class="video-thumb"
                            style="background-image: url('https://img.youtube.com/vi/<%= youtubeVideos[0].video_id %>/maxresdefault.jpg')">
                            <div class="play-button">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
                                    fill="currentColor">
                                    <polygon points="5 3 19 12 5 21 5 3" />
                                </svg>
                            </div>
                        </div>
                        <div class="main-video-info">
                            <h4 class="main-video-title">
                                <%= youtubeVideos[0].title %>
                            </h4>
                        </div>
                    </div>
                <% } else { %>
                    <div class="main-video-card">
                        <div class="video-thumb" style="background: #111; display: flex; align-items: center; justify-content: center; color: #555;">
                            등록된 영상이 없습니다.
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- Playlist Area -->
            <div class="player-sidebar">
                <div class="playlist-header">다음 영상</div>
                <div class="playlist-items">
                    <% if (youtubeVideos && youtubeVideos.length > 1) { %>
                        <% youtubeVideos.forEach((video, index)=> { %>
                            <div class="playlist-item <%= index === 0 ? 'active' : '' %>" data-video-id="<%= video.video_id %>">
                                <div class="item-thumb"
                                    style="background-image: url('https://img.youtube.com/vi/<%= video.video_id %>/mqdefault.jpg')">
                                    <span class="item-duration">
                                        <%= video.duration %>
                                    </span>
                                </div>
                                <div class="item-info">
                                    <p class="item-title">
                                        <%= video.title %>
                                    </p>
                                    <p class="item-channel">KS오토플랜</p>
                                </div>
                            </div>
                        <% }); %>
                    <% } else if (youtubeVideos && youtubeVideos.length === 1) { %>
                        <div class="playlist-item active" data-video-id="<%= youtubeVideos[0].video_id %>">
                            <div class="item-thumb" style="background-image: url('https://img.youtube.com/vi/<%= youtubeVideos[0].video_id %>/mqdefault.jpg')">
                                <span class="item-duration"><%= youtubeVideos[0].duration %></span>
                            </div>
                            <div class="item-info">
                                <p class="item-title"><%= youtubeVideos[0].title %></p>
                                <p class="item-channel">KS오토플랜</p>
                            </div>
                        </div>
                    <% } else { %>
                        <p style="padding: 20px; color: #888; text-align: center;">영상을 등록해주세요.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Planner Section -->
<section class="planner-section">
    <div class="container">
        <div class="section-header">
            <h3 class="section-title">이달의 <span>정예 플래너</span></h3>
            <p class="section-subtitle">KS오토플랜의 검증된 전문가들과 함께 가장 합리적인 견적을 만나보세요.</p>
        </div>

        <div class="planner-grid">
            <% const planners=[ { name: '박민기' , rank: '수석 팀장' , satisfied: '99.8%' , deliveries: '1,842' ,
                tag: '법인/리스 전문' , img: '/images/man1.png' }, { name: '유장현' , rank: '책임 프로' , satisfied: '98.5%' ,
                deliveries: '1,520' , tag: '장기렌트 전문' , img: '/images/man2.png' }, { name: '황호연' , rank: '시니어 파트너' ,
                satisfied: '99.2%' , deliveries: '1,680' , tag: '친절/상세 상담' , img: '/images/man3.png' }, { name: '이준호' ,
                rank: '전문 컨설턴트' , satisfied: '97.9%' , deliveries: '1,240' , tag: '합리적 견적 설계' , img: '/images/man4.png'
                } ]; %>

                <% planners.forEach((planner, index)=> { %>
                    <div class="planner-card" id="planner-<%= index %>">
                        <div class="planner-badge">Top <%= index + 1 %>
                        </div>
                        <div class="planner-photo">
                            <div class="photo-inner" style="background-image: url('<%= planner.img %>')"></div>
                        </div>
                        <div class="planner-info">
                            <div class="planner-meta">
                                <span class="planner-tag">
                                    <%= planner.tag %>
                                </span>
                                <h4 class="planner-name">
                                    <%= planner.name %> <small>
                                            <%= planner.rank %>
                                        </small>
                                </h4>
                            </div>
                            <div class="planner-stats">
                                <div class="stat-item">
                                    <span class="stat-label">만족도</span>
                                    <span class="stat-value">
                                        <%= planner.satisfied %>
                                    </span>
                                </div>
                                <div class="stat-divider"></div>
                                <div class="stat-item">
                                    <span class="stat-label">출고</span>
                                    <span class="stat-value">
                                        <%= planner.deliveries %>건
                                    </span>
                                </div>
                            </div>
                            <button type="button" class="planner-btn btn-planner-inquiry" data-planner-img="<%= planner.img %>" data-planner-name="<%= planner.name %>">이 플래너에게 상담받기</button>
                        </div>
                    </div>
                    <% }); %>
        </div>
    </div>
</section>