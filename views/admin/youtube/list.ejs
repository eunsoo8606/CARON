<div class="page-header d-flex-between">
    <div>
        <h2 class="page-title">유튜브 관리</h2>
        <p class="page-subtitle">메인 페이지에 노출될 유튜브 영상을 관리합니다.</p>
    </div>
    <a href="/console/youtube/new" class="btn-primary-admin">
        <i class="fas fa-plus"></i> 새 영상 등록
    </a>
</div>

<div class="content-card mb-4">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th width="60">순서</th>
                    <th width="180">썸네일</th>
                    <th>제목</th>
                    <th>비디오 ID</th>
                    <th width="80">길이</th>
                    <th width="100">상태</th>
                    <th width="130">등록일</th>
                    <th width="130">관리</th>
                </tr>
            </thead>
            <tbody>
                <% if (videos && videos.length > 0) { %>
                    <% videos.forEach(video => { %>
                        <tr>
                            <td><%= video.order_index %></td>
                            <td>
                                <div class="car-thumb" style="width: 140px; height: 80px;">
                                    <img src="https://img.youtube.com/vi/<%= video.video_id %>/mqdefault.jpg" alt="thumbnail" style="object-fit: cover;">
                                </div>
                            </td>
                            <td class="text-left">
                                <strong><%= video.title %></strong>
                            </td>
                            <td>
                                <code class="badge-brand"><%= video.video_id %></code>
                            </td>
                            <td><%= video.duration || '-' %></td>
                            <td>
                                <% if (video.is_visible) { %>
                                    <span class="status-active">노출중</span>
                                <% } else { %>
                                    <span class="status-inactive">숨김</span>
                                <% } %>
                            </td>
                            <td>
                                <%= video.created_at ? video.created_at.toISOString().split('T')[0] : '-' %>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <a href="/console/youtube/<%= video.id %>" class="btn-edit" title="수정"><i class="fas fa-edit"></i></a>
                                    <button type="button" class="btn-delete" onclick="handleYoutubeDelete(this, <%= video.id %>)" title="삭제"><i class="fas fa-trash-alt"></i></button>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="8" class="empty-row">등록된 유튜브 영상이 없습니다.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
async function handleYoutubeDelete(btn, id) {
    if (!confirm('정말 이 영상을 삭제하시겠습니까?')) return;
    
    try {
        const response = await fetch(`/console/youtube/${id}/delete`, {
            method: 'POST'
        });
        
        if (response.ok) {
            alert('삭제되었습니다.');
            location.reload();
        } else {
            alert('삭제 중 오류가 발생했습니다.');
        }
    } catch (err) {
        console.error(err);
        alert('삭제 요청에 실패했습니다.');
    }
}
</script>

<style>
    .empty-row {
        padding: 100px 0 !important;
        color: #bbb;
        font-weight: 500;
        text-align: center;
    }
</style>
