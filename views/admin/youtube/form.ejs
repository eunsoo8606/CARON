<div class="page-header">
    <h2 class="page-title"><%= video ? '유튜브 영상 수정' : '새 유튜브 영상 등록' %></h2>
    <p class="page-subtitle">유튜브 링크를 입력하면 자동으로 영상 정보가 연동됩니다.</p>
</div>

<form action="/console/youtube/save" method="POST" class="admin-form">
    <% if (video) { %>
        <input type="hidden" name="id" value="<%= video.id %>">
    <% } %>

    <div class="form-grid">
        <div class="form-column">
            <div class="content-card mb-4">
                <h3 class="card-title"><i class="fas fa-video"></i> 영상 정보</h3>
                
                <div class="form-group">
                    <label>유튜브 주소 (URL) <span class="required">*</span></label>
                    <input type="text" name="youtube_url" id="youtubeUrl" class="form-control" 
                           value="<%= video ? 'https://www.youtube.com/watch?v=' + video.video_id : '' %>" 
                           placeholder="https://www.youtube.com/watch?v=... 또는 https://youtu.be/..." required>
                    <p class="form-help">주소를 입력하면 아래 미리보기가 자동으로 업데이트됩니다.</p>
                </div>

                <div class="form-group">
                    <label>영상 제목 <span class="required">*</span></label>
                    <input type="text" name="title" class="form-control" value="<%= video ? video.title : '' %>" placeholder="영상 제목을 입력해주세요" required>
                </div>

                <div class="form-row">
                    <div class="form-group flex-1">
                        <label>재생 시간 (Duration)</label>
                        <input type="text" name="duration" class="form-control" value="<%= video ? video.duration : '' %>" placeholder="예: 12:45">
                    </div>
                    <div class="form-group flex-1">
                        <label>노출 순서</label>
                        <input type="number" name="order_index" class="form-control" value="<%= video ? video.order_index : '0' %>">
                    </div>
                </div>
            </div>
        </div>

        <div class="form-column">
            <div class="content-card">
                <h3 class="card-title"><i class="fas fa-play-circle"></i> 영상 미리보기</h3>
                <div id="videoPreviewArea" style="width: 100%; aspect-ratio: 16/9; background: #000; border-radius: 15px; overflow: hidden; display: flex; align-items: center; justify-content: center; color: #555;">
                    <% if (video) { %>
                        <iframe width="100%" height="100%" src="https://www.youtube.com/embed/<%= video.video_id %>" frameborder="0" allowfullscreen></iframe>
                    <% } else { %>
                        <div class="text-center">
                            <i class="fab fa-youtube" style="font-size: 50px; color: #ff0000; margin-bottom: 10px;"></i>
                            <p style="color: #888;">URL을 입력하면 미리보기가 표시됩니다.</p>
                        </div>
                    <% } %>
                </div>

                <div class="switch-container mt-4">
                    <div class="switch-label">
                        <strong>노출 상태</strong>
                    </div>
                    <div style="display: flex; align-items: center;">
                        <label class="admin-switch">
                            <input type="checkbox" name="is_visible" value="1" <%= (video === null || video.is_visible) ? 'checked' : '' %> id="visibleToggle">
                            <span class="slider"></span>
                        </label>
                        <span class="status-text" id="statusText"><%= (video === null || video.is_visible) ? '노출 중' : '숨김' %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button type="button" class="btn-cancel" onclick="history.back()">취소</button>
        <button type="submit" class="btn-submit"><i class="fas fa-save"></i> 저장하기</button>
    </div>
</form>

<script>
    const youtubeUrlInput = document.getElementById('youtubeUrl');
    const previewArea = document.getElementById('videoPreviewArea');

    function extractVideoId(url) {
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
        const match = url.match(regExp);
        return (match && match[2].length == 11) ? match[2] : null;
    }

    youtubeUrlInput.addEventListener('input', function() {
        const videoId = extractVideoId(this.value);
        if (videoId) {
            previewArea.innerHTML = `<iframe width="100%" height="100%" src="https://www.youtube.com/embed/${videoId}" frameborder="0" allowfullscreen></iframe>`;
        } else {
            previewArea.innerHTML = `
                <div class="text-center">
                    <i class="fab fa-youtube" style="font-size: 50px; color: #ff0000; margin-bottom: 10px;"></i>
                    <p style="color: #888;">올바른 유튜브 주소를 입력해주세요.</p>
                </div>
            `;
        }
    });

    const visibleToggle = document.getElementById('visibleToggle');
    const statusText = document.getElementById('statusText');
    if (visibleToggle && statusText) {
        visibleToggle.addEventListener('change', function() {
            statusText.textContent = this.checked ? '노출 중' : '숨김';
        });
    }
</script>
