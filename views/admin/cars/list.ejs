<div class="page-header d-flex-between">
    <div>
        <h2 class="page-title">차량 관리</h2>
        <p class="page-subtitle">판매 중인 차량 리스트를 관리하고 상세 정보를 수정할 수 있습니다.</p>
    </div>
    <a href="/console/cars/new" class="btn-primary-admin">
        <i class="fas fa-plus"></i> 새 차량 등록
    </a>
</div>

<!-- Search & Filter Area (Optional for now) -->
<div class="content-card mb-4">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th width="60">ID</th>
                    <th width="120">이미지</th>
                    <th width="120">브랜드</th>
                    <th>모델명</th>
                    <th width="120">출고가</th>
                    <th width="120">월 렌트료</th>
                    <th width="80">할인율</th>
                    <th width="100">상태</th>
                    <th width="130">등록일</th>
                    <th width="130">관리</th>
                </tr>
            </thead>
            <tbody>
                <% if (cars && cars.length> 0) { %>
                    <% cars.forEach(car=> { %>
                        <tr>
                            <td>
                                <%= car.id %>
                            </td>
                            <td>
                                <div class="car-thumb">
                                    <% if (car.thumbnail_id) { %>
                                        <img src="/api/image/<%= car.thumbnail_id %>" alt="thumbnail">
                                        <% } else { %>
                                            <div class="no-img">No Img</div>
                                            <% } %>
                                </div>
                            </td>
                            <td><span class="badge-brand text-nowrap">
                                    <%= car.brand %>
                                </span></td>
                            <td class="text-left">
                                <div class="car-name-cell"
                                    style="display: flex; align-items: center; gap: 10px; justify-content: flex-start;">
                                    <strong style="font-size: 16px; color: #333;">
                                        <%= car.name_ko %>
                                    </strong>
                                    <div style="display: flex; gap: 5px;">
                                        <% if (car.is_hot) { %><span class="badge-hot" style="margin: 0;">HOT</span>
                                            <% } %>
                                                <% if (car.is_fast_ship) { %><span class="badge-fast"
                                                        style="margin: 0;">빠른출고</span>
                                                    <% } %>
                                    </div>
                                </div>
                            </td>
                            <td class="text-right">
                                <%= (car.original_price || 0).toLocaleString() %>원
                            </td>
                            <td class="text-right"><strong style="color: #002b5c;">
                                    <%= (car.rent_fee || 0).toLocaleString() %>원
                                </strong></td>
                            <td><span style="color: #f44336; font-weight: 800;">
                                    <%= car.discount_rate %>%
                                </span></td>
                            <td>
                                <% if (car.is_visible) { %>
                                    <span class="status-active">노출중</span>
                                    <% } else { %>
                                        <span class="status-inactive">미노출</span>
                                        <% } %>
                            </td>
                            <td>
                                <%= car.created_at ? car.created_at.toISOString().split('T')[0] : '-' %>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <a href="/console/cars/<%= car.id %>" class="btn-edit" title="수정"><i
                                            class="fas fa-edit"></i></a>
                                    <button type="button" class="btn-delete"
                                        onclick="handleCarDelete(this, <%= car.id %>)" title="삭제"><i
                                            class="fas fa-trash-alt"></i></button>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="10" class="empty-row">등록된 차량이 없습니다.</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
    </div>
</div>

<style>
    .empty-row {
        padding: 100px 0 !important;
        color: #bbb;
        font-weight: 500;
        text-align: center;
    }
</style>