<div class="page-header">
    <h2 class="page-title"><%= car ? '차량 수정' : '새 차량 등록' %></h2>
    <p class="page-subtitle">차량의 상세 스펙과 판매 조건을 설정합니다.</p>
</div>

<form action="/console/cars/save" method="POST" enctype="multipart/form-data" class="admin-form">
    <% if (car) { %>
        <input type="hidden" name="id" value="<%= car.id %>">
    <% } %>

    <div class="form-grid">
        <!-- Left Column: Basic Info -->
        <div class="form-column">
            <div class="content-card mb-4">
                <h3 class="card-title"><i class="fas fa-info-circle"></i> 기본 정보</h3>
                
                <div class="form-group">
                    <label>브랜드 <span class="required">*</span></label>
                    <select name="brand" class="form-control" required>
                        <option value="">브랜드를 선택하세요</option>
                        <option value="현대" <%= car && car.brand === '현대' ? 'selected' : '' %>>현대</option>
                        <option value="기아" <%= car && car.brand === '기아' ? 'selected' : '' %>>기아</option>
                        <option value="르노코리아" <%= car && car.brand === '르노코리아' ? 'selected' : '' %>>르노코리아</option>
                        <option value="KGM" <%= car && car.brand === 'KGM' ? 'selected' : '' %>>KGM</option>
                        <option value="쉐보레" <%= car && car.brand === '쉐보레' ? 'selected' : '' %>>쉐보레</option>
                        <option value="제네시스" <%= car && car.brand === '제네시스' ? 'selected' : '' %>>제네시스</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>차량명 (한글) <span class="required">*</span></label>
                    <input type="text" name="name_ko" class="form-control" value="<%= car ? car.name_ko : '' %>" placeholder="예: 그랜저 하이브리드" required>
                </div>

                <div class="form-group">
                    <label>차량명 (영문)</label>
                    <input type="text" name="name_en" class="form-control" value="<%= car ? car.name_en : '' %>" placeholder="예: Grandeur Hybrid">
                </div>

                <div class="form-row">
                    <div class="form-group flex-1">
                        <label>연식</label>
                        <div class="input-with-text">
                            <input type="number" name="year" class="form-control" value="<%= car ? car.year : '' %>" placeholder="2025">
                            <span class="unit">년형</span>
                        </div>
                    </div>
                    <div class="form-group flex-1">
                        <label>인승</label>
                        <div class="input-with-text">
                            <input type="number" name="capacity" class="form-control" value="<%= car ? car.capacity : '' %>" placeholder="5">
                            <span class="unit">인승</span>
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group flex-1">
                        <label>차종</label>
                        <select name="car_type" class="form-control">
                            <option value="세단" <%= car && car.car_type === '세단' ? 'selected' : '' %>>세단</option>
                            <option value="SUV" <%= car && car.car_type === 'SUV' ? 'selected' : '' %>>SUV</option>
                            <option value="쿠페" <%= car && car.car_type === '쿠페' ? 'selected' : '' %>>쿠페</option>
                            <option value="전기차" <%= car && car.car_type === '전기차' ? 'selected' : '' %>>전기차</option>
                        </select>
                    </div>
                    <div class="form-group flex-1">
                        <label>연료</label>
                        <select name="fuel_type" class="form-control">
                            <option value="가솔린" <%= car && car.fuel_type === '가솔린' ? 'selected' : '' %>>가솔린</option>
                            <option value="디젤" <%= car && car.fuel_type === '디젤' ? 'selected' : '' %>>디젤</option>
                            <option value="하이브리드" <%= car && car.fuel_type === '하이브리드' ? 'selected' : '' %>>하이브리드</option>
                            <option value="전기" <%= car && car.fuel_type === '전기' ? 'selected' : '' %>>전기</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="content-card">
                <h3 class="card-title"><i class="fas fa-won-sign"></i> 가격 및 조건</h3>
                <div class="form-group">
                    <label>월 렌트료 <span class="required">*</span></label>
                    <div class="input-with-text">
                        <input type="text" name="rent_fee" class="form-control format-price" value="<%= car ? car.rent_fee.toLocaleString() : '' %>" placeholder="0" required>
                        <span class="unit">원</span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group flex-1">
                        <label>차량 출고가</label>
                        <div class="input-with-text">
                            <input type="text" name="original_price" class="form-control format-price" value="<%= car ? car.original_price.toLocaleString() : '' %>" placeholder="0">
                            <span class="unit">원</span>
                        </div>
                    </div>
                    <div class="form-group flex-1">
                        <label>할인율 (%)</label>
                        <input type="number" step="0.1" name="discount_rate" class="form-control" value="<%= car ? car.discount_rate : '0' %>">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group flex-1">
                        <label>선수금 기준</label>
                        <div class="input-with-text">
                            <input type="number" name="down_payment" class="form-control" value="<%= car ? car.down_payment : '30' %>" placeholder="30">
                            <span class="unit">%</span>
                        </div>
                    </div>
                    <div class="form-group flex-1">
                        <label>계약기간</label>
                        <div class="input-with-text">
                            <input type="number" name="period" class="form-control" value="<%= car ? car.period : '36' %>" placeholder="36">
                            <span class="unit">개월</span>
                        </div>
                    </div>
                    <div class="form-group flex-1">
                        <label>주행거리 기준</label>
                        <div class="input-with-text">
                            <input type="number" name="mileage" class="form-control" value="<%= car ? car.mileage : '2' %>" placeholder="2">
                            <span class="unit">만km</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Media & Marketing -->
        <div class="form-column">
            <div class="content-card mb-4">
                <h3 class="card-title"><i class="fas fa-image"></i> 대표 이미지</h3>
                <div class="image-upload-box" id="imagePreviewBox">
                    <% if (car && car.thumbnail_id) { %>
                        <img src="/api/image/<%= car.thumbnail_id %>" class="preview-img">
                    <% } else { %>
                        <div class="upload-placeholder">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <p>클릭하여 차량 사진 업로드</p>
                        </div>
                    <% } %>
                    <input type="file" name="thumbnail" id="thumbnailInput" accept="image/*" class="file-input">
                </div>
                <p class="form-help">권장 사이즈: 800x500px (JPG, PNG)</p>
            </div>

            <div class="content-card">
                <h3 class="card-title"><i class="fas fa-tags"></i> 마케팅 및 노출</h3>
                <div class="checkbox-group">
                    <label class="checkbox-item">
                        <input type="checkbox" name="is_hot" value="1" <%= car && car.is_hot ? 'checked' : '' %>>
                        <span class="checkmark"></span>
                        <strong>HOT 차량</strong> (추천 차량 표시)
                    </label>
                    <label class="checkbox-item">
                        <input type="checkbox" name="is_fast_ship" value="1" <%= car && car.is_fast_ship ? 'checked' : '' %>>
                        <span class="checkmark"></span>
                        <strong>빠른 출고</strong> (즉시 출고 가능)
                    </label>
                    <label class="checkbox-item">
                        <input type="checkbox" name="is_visible" value="1" <%= (car === null || car.is_visible) ? 'checked' : '' %>>
                        <span class="checkmark"></span>
                        <strong>노출 활성화</strong> (사이트에 노출)
                    </label>
                </div>

                <div class="form-group mt-4">
                    <label>해쉬태그</label>
                    <textarea name="hashtags" class="form-control" rows="2" placeholder="콤마(,)로 구분하여 입력 (예: 인기차종, 가성비, 패밀리카)"><%= car ? car.hashtags : '' %></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button type="button" class="btn-cancel" onclick="history.back()">취소</button>
        <button type="submit" class="btn-submit"><i class="fas fa-save"></i> 저장하기</button>
    </div>
</form>

<script>
    // 금액 포맷팅 함수 (콤마 추가)
    function formatNumber(n) {
        return n.replace(/\D/g, "").replace(/\B(?=(\d{3})+(?!\d))/g, ",");
    }

    // 모든 금액 입력창에 이벤트 연결
    document.querySelectorAll('.format-price').forEach(input => {
        input.addEventListener('input', function(e) {
            const cursor_pos = e.target.selectionStart;
            const old_length = e.target.value.length;
            
            e.target.value = formatNumber(e.target.value);
            
            // 커서 위치 보정 (콤마 추가로 인한 밀림 방지)
            const new_length = e.target.value.length;
            e.target.setSelectionRange(cursor_pos + (new_length - old_length), cursor_pos + (new_length - old_length));
        });
    });

    // 이미지 미리보기 기능
    document.getElementById('thumbnailInput').addEventListener('change', function(e) {
        const reader = new FileReader();
        reader.onload = function(event) {
            const box = document.getElementById('imagePreviewBox');
            box.innerHTML = `<img src="${event.target.result}" class="preview-img">`;
        };
        if(this.files[0]) reader.readAsDataURL(this.files[0]);
    });
</script>
