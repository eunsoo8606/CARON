<!-- Planner Specific Assets -->
<script src="/js/admin/planners.js?v=<%= Date.now() %>"></script>

<div class="page-header d-flex-between">
    <div>
        <h2 class="page-title">플래너 관리</h2>
        <p class="page-subtitle">메인 페이지에 노출될 정예 플래너를 관리합니다.</p>
    </div>
    <a href="/console/planners/new" class="btn-primary-admin btn-magenta">
        <i class="fas fa-plus-circle"></i> 신규 플래너 등록
    </a>
</div>

<div class="content-card mb-4">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th width="80">출고건수</th>
                    <th width="80">사진</th>
                    <th width="120">이름</th>
                    <th width="120">직급</th>
                    <th>자기소개</th>
                    <th width="120">관리</th>
                </tr>
            </thead>
            <tbody>
                <% if (planners && planners.length > 0) { %>
                    <% planners.forEach(planner => { %>
                    <tr>
                        <td style="font-weight: 800; color: #de1f7f;"><%= planner.deliveries %>건</td>
                        <td>
                            <div class="admin-thumb-circle">
                                <% if (planner.getDataValue('profile_img') && planner.getDataValue('profile_img') !== '/images/default_user.png') { %>
                                    <img src="<%= planner.getDataValue('profile_img') %>" alt="profile">
                                <% } else { %>
                                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #f8f9fa;">
                                        <i class="fas fa-user-tie" style="color: #ccc; font-size: 20px;"></i>
                                    </div>
                                <% } %>
                            </div>
                        </td>
                        <td><strong style="font-size: 16px; color: #333;"><%= planner.Admin ? planner.Admin.name : '이름없음' %></strong></td>
                        <td><%= planner.position || '-' %></td>
                        <td>
                            <div style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 39px; text-align: center; line-height: 1.5; color: #666;">
                                <%= planner.intro || '자기소개가 없습니다.' %>
                            </div>
                        </td>
                        <td>
                            <div class="action-btns">
                                <a href="/console/planners/edit/<%= planner.id %>" class="btn-edit" title="수정">
                                    <i class="fas fa-edit"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="6" style="padding: 100px 0; text-align: center; color: #999;">등록된 플래너가 없습니다.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
