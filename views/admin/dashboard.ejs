<div class="dashboard-container">
    <div class="page-header">
        <h2 class="page-title">대시보드</h2>
        <p class="page-subtitle">실시간 서비스 현황을 한눈에 확인하세요.</p>
    </div>

    <!-- Stat Cards Grid -->
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-icon" style="background: #e3f2fd; color: #2196f3;">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-info">
                <div class="stat-label">일일 방문자</div>
                <div class="stat-value"><%= stats.visitorCount.toLocaleString() %></div>
                <div class="stat-trend up">
                    <i class="fas fa-arrow-up"></i> New <span>today</span>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background: #fff3e0; color: #ff9800;">
                <i class="fas fa-envelope-open-text"></i>
            </div>
            <div class="stat-info">
                <div class="stat-label">문의 건수</div>
                <div class="stat-value"><%= stats.inquiryCount.toLocaleString() %></div>
                <div class="stat-trend up">
                    <i class="fas fa-arrow-up"></i> Total <span>received</span>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background: #e8f5e9; color: #4caf50;">
                <i class="fas fa-car"></i>
            </div>
            <div class="stat-info">
                <div class="stat-label">차량 등록수</div>
                <div class="stat-value"><%= stats.carCount.toLocaleString() %></div>
                <div class="stat-trend">
                    <i class="fas fa-car-side"></i> Managed <span>units</span>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background: #f3e5f5; color: #9c27b0;">
                <i class="fas fa-user-tie"></i>
            </div>
            <div class="stat-info">
                <div class="stat-label">플래너 수</div>
                <div class="stat-value"><%= stats.plannerCount.toLocaleString() %></div>
                <div class="stat-trend">
                    <i class="fas fa-user-plus"></i> Active <span>team</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Future Content Placeholder (Recent Activity or Charts) -->
    <div class="dashboard-row" style="margin-top: 40px; display: grid; grid-template-columns: 2fr 1fr; gap: 30px;">
        <div class="content-card" style="background: white; padding: 30px; border-radius: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.03); min-height: 400px;">
            <h3 style="margin-top: 0; font-size: 18px; font-weight: 800;">최근 상담 신청 현황</h3>
            <div style="text-align: center; color: #888; padding-top: 150px;">
                <i class="fas fa-table" style="font-size: 40px; margin-bottom: 15px; opacity: 0.3;"></i>
                <p>최근 상담 내역이 여기에 표시됩니다.</p>
            </div>
        </div>
        <div class="content-card" style="background: white; padding: 30px; border-radius: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.03);">
            <h3 style="margin-top: 0; font-size: 18px; font-weight: 800;">시스템 로그</h3>
            <div style="text-align: center; color: #888; padding-top: 150px;">
                <p>최근 로그가 표시됩니다.</p>
            </div>
        </div>
    </div>
</div>
